{
  "id": "set_groups_state",
  "title": {
    "en": "Set multiple groups state",
    "it": "Imposta stato di più gruppi"
  },
  "titleFormatted": {
    "en": "Set groups [[groups]] to [[operation]]",
    "it": "Imposta i gruppi [[groups]] su [[operation]]"
  },
  "args": [
    {
      "name": "device",
      "type": "device",
      "filter": "driver_id=alarm_hub"
    },
    {
      "name": "groups",
      "type": "text",
      "title": {
        "en": "Groups",
        "it": "Gruppi"
      },
      "placeholder": {
        "en": "1,2,3",
        "it": "1,2,3"
      }
    },
    {
      "name": "operation",
      "type": "dropdown",
      "title": {
        "en": "Operation",
        "it": "Operazione"
      },
      "values": [
        { "id": "arm", "title": { "en": "Arm", "it": "Attiva" } },
        { "id": "disarm", "title": { "en": "Disarm", "it": "Disattiva" } }
      ]
    }
  ]
}
