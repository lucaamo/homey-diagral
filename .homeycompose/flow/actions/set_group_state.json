{
  "id": "set_group_state",
  "title": {
    "en": "Set group state",
    "it": "Imposta stato gruppo"
  },
  "titleFormatted": {
    "en": "Set group [[group]] to [[operation]]",
    "it": "Imposta il gruppo [[group]] su [[operation]]"
  },
  "args": [
    {
      "name": "device",
      "type": "device",
      "filter": "driver_id=alarm_hub"
    },
    {
      "name": "group",
      "type": "dropdown",
      "title": {
        "en": "Group",
        "it": "Gruppo"
      },
      "values": [
        { "id": "1", "title": { "en": "Group 1", "it": "Gruppo 1" } },
        { "id": "2", "title": { "en": "Group 2", "it": "Gruppo 2" } },
        { "id": "3", "title": { "en": "Group 3", "it": "Gruppo 3" } }
      ]
    },
    {
      "name": "operation",
      "type": "dropdown",
      "title": {
        "en": "Operation",
        "it": "Operazione"
      },
      "values": [
        { "id": "arm", "title": { "en": "Arm", "it": "Attiva" } },
        { "id": "disarm", "title": { "en": "Disarm", "it": "Disattiva" } }
      ]
    }
  ]
}
