{
  "id": "alarm_hub",
  "name": {
    "en": "Diagral Alarm",
    "it": "Allarme Diagral"
  },
  "class": "sensor",
  "platforms": [
    "local"
  ],
  "connectivity": [
    "cloud"
  ],
  "images": {
    "small": "/drivers/alarm_hub/assets/images/small.png",
    "large": "/drivers/alarm_hub/assets/images/large.png"
  },
  "capabilities": [
    "diagral_alarm_mode",
    "diagral_alarm_mode_label",
    "diagral_alarm_triggered",
    "diagral_anomalies_count",
    "diagral_anomalies_summary",
    "diagral_active_groups",
    "diagral_active_groups_names",
    "diagral_active_groups_ids",
    "diagral_last_sync"
  ],
  "capabilitiesOptions": {
    "diagral_alarm_mode": {
      "title": {
        "en": "Alarm mode",
        "it": "Modalità allarme"
      }
    },
    "diagral_alarm_mode_label": {
      "title": {
        "en": "Alarm status",
        "it": "Stato allarme"
      }
    },
    "diagral_alarm_triggered": {
      "title": {
        "en": "Alarm triggered",
        "it": "Allarme scattato"
      },
      "insightsTitleTrue": {
        "en": "Alarm triggered",
        "it": "Allarme scattato"
      },
      "insightsTitleFalse": {
        "en": "Alarm restored",
        "it": "Allarme rientrato"
      }
    },
    "diagral_anomalies_count": {
      "title": {
        "en": "Anomalies",
        "it": "Anomalie"
      }
    },
    "diagral_anomalies_summary": {
      "title": {
        "en": "Anomalies summary",
        "it": "Riepilogo anomalie"
      }
    },
    "diagral_active_groups": {
      "title": {
        "en": "Active groups",
        "it": "Gruppi attivi"
      }
    },
    "diagral_active_groups_names": {
      "title": {
        "en": "Active group names",
        "it": "Nomi gruppi attivi"
      }
    },
    "diagral_active_groups_ids": {
      "title": {
        "en": "Active group IDs",
        "it": "ID gruppi attivi"
      }
    },
    "diagral_last_sync": {
      "title": {
        "en": "Last sync",
        "it": "Ultima sincronizzazione"
      }
    }
  },
  "energy": {
    "approximation": {
      "usageOn": 1,
      "usageOff": 1
    }
  },
  "settings": [
    {
      "id": "username",
      "type": "text",
      "label": {
        "en": "Email",
        "it": "Email"
      },
      "value": ""
    },
    {
      "id": "password",
      "type": "password",
      "label": {
        "en": "Password",
        "it": "Password"
      },
      "value": ""
    },
    {
      "id": "serialId",
      "type": "text",
      "label": {
        "en": "Serial ID",
        "it": "Serial ID"
      },
      "value": ""
    },
    {
      "id": "pinCode",
      "type": "password",
      "label": {
        "en": "PIN code",
        "it": "Codice PIN"
      },
      "value": ""
    },
    {
      "id": "webhookId",
      "type": "text",
      "label": {
        "en": "Webhook ID",
        "it": "Webhook ID"
      },
      "value": "",
      "hint": {
        "en": "Optional. Enables Diagral real-time webhook events.",
        "it": "Opzionale. Abilita gli eventi webhook Diagral in tempo reale."
      }
    },
    {
      "id": "webhookSecret",
      "type": "password",
      "label": {
        "en": "Webhook secret",
        "it": "Webhook secret"
      },
      "value": "",
      "hint": {
        "en": "Keep this value private.",
        "it": "Mantieni questo valore privato."
      }
    },
    {
      "id": "pollInterval",
      "type": "number",
      "label": {
        "en": "Polling interval (seconds)",
        "it": "Intervallo polling (secondi)"
      },
      "value": 180,
      "attr": {
        "min": 60,
        "max": 3600
      }
    }
  ],
  "pair": [
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "next": "add_devices"
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "repair": [
    {
      "id": "credentials"
    }
  ]
}
